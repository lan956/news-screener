# ── Telegram ─────────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_TOKEN=your_bot_token_here

# Your chat ID (use @userinfobot or @getidsbot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Schedule ──────────────────────────────────────────────────────────────────
# Time to send the daily digest (24-hour format, server local time)
SEND_TIME=08:00

# ── Scraping ──────────────────────────────────────────────────────────────────
# Max number of articles to pull per site
MAX_ARTICLES=5
